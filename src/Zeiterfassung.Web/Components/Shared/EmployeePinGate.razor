@*  PIN gate for SelfService.

    Wraps a SelfService page. Behavior:
    - If the current cookie identity is an Admin, the gate is BYPASSED:
      the page renders immediately and the parent can let the admin
      choose any employee.
    - Otherwise, the gate shows an employee picker + PIN keypad. On a
      correct PIN, EmployeeSessionService.SignIn(empId) is called and
      the page renders with the employee locked to that id (no picker).
    - Sessions expire after EmployeeSessionService.IdleTimeout (10 min).

    Parent usage:
        <EmployeePinGate Context="ctx">
            ... your page content, with ctx.EmployeeId and ctx.IsAdmin ...
        </EmployeePinGate>
*@

@inject ZeiterfassungDbContext Db
@inject PinAuthenticationService PinAuth
@inject Zeiterfassung.Web.Services.EmployeeSessionService Session
@inject NavigationManager Nav

@if (_isAdmin || Session.IsAuthenticated)
{
    Session.Touch();
    @ChildContent(new GateContext(Session.AuthenticatedEmployeeId, _isAdmin, SignOut))
}
else
{
    <div class="pingate-shell">
        <div class="pingate-card">
            <div class="pingate-head">
                <div class="pingate-mark">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
                    </svg>
                </div>
                <div>
                    <div class="pingate-title">Persönlicher Zugang</div>
                    <div class="pingate-sub">PIN eingeben um eigene Zeiten zu sehen</div>
                </div>
            </div>

            @if (_selectedEmployee == null)
            {
                <label class="z-label">Mitarbeiter</label>
                <select class="form-select" @onchange="OnEmployeeSelected">
                    <option value="">— bitte wählen —</option>
                    @foreach (var emp in _employees)
                    {
                        <option value="@emp.Id">@emp.LastName, @emp.FirstName</option>
                    }
                </select>
            }
            else
            {
                <div class="pingate-selected">
                    <div class="pingate-avatar">@Initials(_selectedEmployee)</div>
                    <div>
                        <div class="pingate-name">@_selectedEmployee.FirstName @_selectedEmployee.LastName</div>
                        <button type="button" class="pingate-change" @onclick="ResetSelection">
                            Anderer Mitarbeiter
                        </button>
                    </div>
                </div>

                <label class="z-label" style="margin-top:1rem">PIN (6-stellig)</label>
                <input type="password" class="form-control" maxlength="6" inputmode="numeric"
                       autocomplete="off" autofocus
                       placeholder="••••••"
                       @bind="_pin" @bind:event="oninput"
                       @onkeyup="OnPinKeyUp"
                       style="letter-spacing:0.5rem; font-size:1.125rem; text-align:center" />

                @if (_pinError != null)
                {
                    <div class="alert alert-danger mt-2" role="alert">@_pinError</div>
                }

                <button type="button" class="btn btn-primary w-100 mt-3" @onclick="VerifyPin"
                        disabled="@(_pin.Length != 6 || _busy)">
                    @if (_busy)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    PIN bestätigen
                </button>
            }

            <div class="pingate-foot">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z"/>
                </svg>
                Datenschutz: nach 10 Minuten Inaktivität wird die Sitzung beendet.
                Sie sehen ausschließlich Ihre eigenen Daten.
            </div>
        </div>
    </div>
}

<style>
    .pingate-shell {
        display: flex; align-items: flex-start; justify-content: center;
        padding: 1rem 0;
    }
    .pingate-card {
        background: #fff;
        border: 1px solid rgba(26, 24, 21, 0.08);
