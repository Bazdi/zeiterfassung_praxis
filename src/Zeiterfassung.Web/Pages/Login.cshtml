@page
@model Zeiterfassung.Web.Pages.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin-Login — Zeiterfassung</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body {
            margin: 0; height: 100%;
            background: #0f1117;
            color: #e2e8f0;
            font-family: 'Segoe UI', system-ui, sans-serif;
            -webkit-font-smoothing: antialiased;
        }
        .page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .card {
            width: 100%;
            max-width: 400px;
            background: #1a1d27;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 16px;
            padding: 2.5rem;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        }
        .logo {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            margin-bottom: 2rem;
            font-size: 1rem;
            font-weight: 600;
            color: #94a3b8;
        }
        h1 {
            font-size: 1.4rem;
            font-weight: 600;
            margin: 0 0 0.25rem;
            color: #e2e8f0;
            text-wrap: balance;
        }
        .subtitle {
            font-size: 0.85rem;
            color: #64748b;
            margin: 0 0 2rem;
        }
        label {
            display: block;
            font-size: 0.8rem;
            color: #94a3b8;
            margin-bottom: 0.35rem;
        }
        input {
            width: 100%;
            padding: 0.7rem 0.875rem;
            background: #22263a;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: #e2e8f0;
            font-size: 0.9rem;
            margin-bottom: 1rem;
            outline: none;
            transition: border-color 0.15s ease;
        }
        input:focus {
            border-color: #4f8ef7;
            box-shadow: 0 0 0 3px rgba(79,142,247,0.2);
        }
        .error {
            background: rgba(248,113,113,0.1);
            border: 1px solid rgba(248,113,113,0.3);
            border-radius: 8px;
            padding: 0.75rem 1rem;
            color: #fca5a5;
            font-size: 0.85rem;
            margin-bottom: 1rem;
        }
        button {
            width: 100%;
            padding: 0.8rem;
            background: #4f8ef7;
            border: none;
            border-radius: 8px;
            color: white;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.12s ease, transform 0.1s ease;
        }
        button:hover { background: #6aa3ff; }
        button:active { transform: scale(0.96); }
        .footer-link {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.8rem;
        }
        .footer-link a { color: #4f8ef7; text-decoration: none; }
        .footer-link a:hover { text-decoration: underline; }
    </style>
</head>
<body>
<div class="page">
    <div class="card">
        <div class="logo">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            Zeiterfassung Arztpraxis
        </div>
        <h1>Admin-Anmeldung</h1>
        <p class="subtitle">Nur für autorisiertes Praxispersonal.</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error">@Model.ErrorMessage</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <label for="username">Benutzername</label>
            <input id="username" name="Username" type="text" autocomplete="username"
                   value="@Model.Username" autofocus required />

            <label for="password">Passwort</label>
            <input id="password" name="Password" type="password" autocomplete="current-password" required />

            <button type="submit">Anmelden</button>
        </form>

        <div class="footer-link">
            <a href="/terminal">→ Zum Stempel-Terminal</a>
        </div>
    </div>
</div>
</body>
</html>
