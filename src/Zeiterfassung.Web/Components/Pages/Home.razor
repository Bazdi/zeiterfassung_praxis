@page "/"

<PageTitle>Zeiterfassung — Übersicht</PageTitle>

<h1>Übersicht</h1>

<div class="dashboard-grid">
    <a href="/terminal" class="dashboard-card primary">
        <div class="card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
            </svg>
        </div>
        <div class="card-body">
            <div class="card-title">Terminal öffnen</div>
            <div class="card-desc">Stempel-Kiosk im Vollbild für alle Mitarbeiter starten.</div>
        </div>
        <div class="card-footer">
            <span class="card-arrow">
                Öffnen
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 6l6 6-6 6"/></svg>
            </span>
        </div>
    </a>

    <a href="/selfservice" class="dashboard-card">
        <div class="card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 6h16M4 12h16M4 18h10"/>
            </svg>
        </div>
        <div class="card-body">
            <div class="card-title">Meine Zeiten</div>
            <div class="card-desc">Eigene Stempelzeiten und Überstunden-Saldo einsehen.</div>
        </div>
        <div class="card-footer">
            <span class="card-arrow">
                Öffnen
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 6l6 6-6 6"/></svg>
            </span>
        </div>
    </a>

    <a href="/admin/mitarbeiter" class="dashboard-card">
        <div class="card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="8" r="3.5"/><path d="M2 20c.7-3 3.5-5 7-5s6.3 2 7 5"/>
                <circle cx="17" cy="9" r="2.5"/><path d="M16 14c2.5 0 4.5 1.4 5 4"/>
            </svg>
        </div>
        <div class="card-body">
            <div class="card-title">Mitarbeiter</div>
            <div class="card-desc">Konten verwalten, PINs zurücksetzen, Rollen ändern.</div>
        </div>
        <div class="card-footer">
            <span class="card-arrow">
                Öffnen
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 6l6 6-6 6"/></svg>
            </span>
        </div>
    </a>

    <a href="/admin/integritaet" class="dashboard-card">
        <div class="card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z"/>
            </svg>
        </div>
        <div class="card-body">
            <div class="card-title">Integritätsprüfung</div>
            <div class="card-desc">GoBD-Hash-Kette der Stempelungen verifizieren.</div>
        </div>
        <div class="card-footer">
            <span class="card-arrow">
                Öffnen
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 6l6 6-6 6"/></svg>
            </span>
        </div>
    </a>
</div>

<style>
    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
        gap: clamp(0.625rem, 1.5vw, 1rem);
        margin-top: 0.25rem;
    }

    .dashboard-card {
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
        padding: 1.375rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        text-decoration: none;
        color: var(--text);
        transition: background 0.1s ease, border-color 0.1s ease, transform 0.08s ease;
        min-height: 152px;
    }

    .dashboard-card:hover {
        background: var(--surface-2);
        border-color: var(--border-strong);
        color: var(--text);
        transform: translateY(-1px);
    }

    .dashboard-card:active { transform: scale(0.97); }

    .dashboard-card.primary {
        border-color: var(--accent-border);
        background: linear-gradient(180deg, var(--accent-dim), var(--surface));
    }

    .dashboard-card.primary:hover {
        background: linear-gradient(180deg, rgba(31,91,76,0.12), var(--surface-2));
        border-color: var(--accent);
    }

    .card-icon {
        width: 44px; height: 44px;
        border-radius: 10px;
        background: var(--surface-2);
        border: 1px solid var(--border);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        color: var(--accent);
    }

    .dashboard-card.primary .card-icon {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff;
    }

    .card-body { flex: 1; }

    .card-title {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--text);
        letter-spacing: -0.01em;
        margin-bottom: 0.25rem;
    }

    .card-desc {
        font-size: 0.8125rem;
        color: var(--text-dim);
        line-height: 1.45;
    }

    .card-footer {
        display: flex;
        align-items: center;
        justify-content: flex-end;
    }

    .card-arrow {
        display: flex; align-items: center; gap: 0.25rem;
        font-size: 0.8125rem; font-weight: 500;
        color: var(--text-muted);
        transition: color 0.1s ease, gap 0.1s ease;
    }

    .dashboard-card.primary .card-arrow { color: var(--accent); }

    .dashboard-card:hover .card-arrow {
        color: var(--text-dim);
        gap: 0.375rem;
    }

    .dashboard-card.primary:hover .card-arrow { color: var(--accent); }
</style>
