</style>

@code {
    [Parameter, EditorRequired] public RenderFragment<GateContext> ChildContent { get; set; } = default!;

    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    private List<Employee> _employees = new();
    private Employee? _selectedEmployee;
    private string _pin = "";
    private string? _pinError;
    private bool _busy;
    private bool _isAdmin;

    protected override async Task OnInitializedAsync()
    {
        _employees = await Db.Employees
            .Where(e => e.IsActive)
            .OrderBy(e => e.LastName).ThenBy(e => e.FirstName)
            .ToListAsync();

        if (AuthStateTask != null)
        {
            var s = await AuthStateTask;
            _isAdmin = s.User.IsInRole("Admin");
        }
    }

    private void OnEmployeeSelected(ChangeEventArgs e)
    {
        _pinError = null;
        _pin = "";
        if (int.TryParse(e.Value?.ToString(), out var id))
            _selectedEmployee = _employees.FirstOrDefault(x => x.Id == id);
        else
            _selectedEmployee = null;
    }

    private void ResetSelection()
    {
        _selectedEmployee = null;
        _pin = "";
        _pinError = null;
    }

    private async Task OnPinKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && _pin.Length == 6) await VerifyPin();
    }

    private async Task VerifyPin()
    {
        if (_selectedEmployee == null || _pin.Length != 6) return;
        _busy = true;
        _pinError = null;

        try
        {
            var fresh = await Db.Employees.FindAsync(_selectedEmployee.Id);
            if (fresh == null) { _pinError = "Mitarbeiter nicht gefunden."; return; }

            var result = PinAuth.Authenticate(fresh, _pin);
            await Db.SaveChangesAsync();

            if (!result.Success)
            {
                _pin = "";
                if (result.RequiresAdminReset)
                    _pinError = "Konto gesperrt — bitte Admin kontaktieren.";
                else if (result.LockoutRemainingSeconds.HasValue)
                    _pinError = $"Gesperrt für {result.LockoutRemainingSeconds}s.";
                else
                    _pinError = $"Falsche PIN. {result.RemainingAttempts} Versuche verbleibend.";
                return;
            }

            Session.SignIn(fresh.Id);
        }
        finally { _busy = false; }
    }

    private void SignOut()
    {
        Session.SignOut();
        _selectedEmployee = null;
        _pin = "";
        _pinError = null;
    }

    private static string Initials(Employee e)
        => ((e.FirstName.Length > 0 ? e.FirstName[0].ToString() : "")
          + (e.LastName.Length  > 0 ? e.LastName[0].ToString()  : "")).ToUpperInvariant();

    public record GateContext(int? EmployeeId, bool IsAdmin, Action SignOut);
}
