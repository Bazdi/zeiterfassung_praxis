@page
@model Zeiterfassung.Web.Pages.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin-Login — Zeiterfassung</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body {
            margin: 0; height: 100%;
            background: #f4f1ea;
            color: #1a1815;
            font-family: 'Segoe UI', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
            -webkit-font-smoothing: antialiased;
            text-rendering: optimizeLegibility;
        }
        .page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            position: relative;
            overflow: hidden;
        }
        /* Subtle paper grain — radial wash + faint grid */
        .page::before, .page::after {
            content: ''; position: absolute; inset: 0; pointer-events: none;
        }
        .page::before {
            background:
              radial-gradient(720px 520px at 30% 20%, #e8f0ec, transparent 60%),
              radial-gradient(600px 400px at 80% 90%, rgba(31,91,76,0.04), transparent 60%);
        }
        .page::after {
            opacity: 0.5;
            background-image:
              linear-gradient(rgba(26, 24, 21, 0.08) 1px, transparent 1px),
              linear-gradient(90deg, rgba(26, 24, 21, 0.08) 1px, transparent 1px);
            background-size: 56px 56px;
            -webkit-mask-image: radial-gradient(circle at center, black 0%, transparent 75%);
                    mask-image: radial-gradient(circle at center, black 0%, transparent 75%);
        }
        .wrap { position: relative; width: 100%; max-width: 460px; }
        .brand-head { text-align: center; margin-bottom: 1.75rem; }
        .brand-mark {
            display: inline-flex; align-items: center; justify-content: center;
            width: 64px; height: 64px;
            border-radius: 16px;
            background: #1f5b4c;
            color: #fff;
            margin-bottom: 1.125rem;
        }
        .brand-title {
            font-size: 1.625rem; font-weight: 600;
            letter-spacing: -0.03em;
            color: #1a1815;
            margin: 0;
        }
        .brand-sub {
            font-size: 0.84375rem; color: #5a544c;
            margin-top: 0.25rem;
        }
        .card {
            background: #ffffff;
            border: 1px solid rgba(26, 24, 21, 0.08);
            border-radius: 12px;
            padding: 1.75rem;
        }
        .card-heading { font-size: 1.0625rem; font-weight: 600; letter-spacing: -0.01em; color: #1a1815; margin: 0; }
        .card-sub { font-size: 0.78125rem; color: #5a544c; margin-top: 0.1875rem; margin-bottom: 1.375rem; }
        label {
            display: block; font-size: 0.71875rem; color: #5a544c;
            font-weight: 500; margin-bottom: 0.375rem; letter-spacing: 0.01em;
        }
        input {
            width: 100%;
            padding: 0.625rem 0.75rem;
            background: #ffffff;
            border: 1px solid rgba(26, 24, 21, 0.16);
            border-radius: 8px;
            color: #1a1815;
            font-size: 0.875rem;
            font-family: inherit;
            margin-bottom: 0.875rem;
            outline: none;
            min-height: 40px;
            transition: border-color 0.12s, box-shadow 0.12s;
        }
        input::placeholder { color: #8d877d; }
        input:focus {
            border-color: #1f5b4c;
            box-shadow: 0 0 0 3px rgba(31, 91, 76, 0.08);
        }
        .error {
            display: flex; align-items: center; gap: 0.625rem;
            background: #fbe9e4;
            border: 1px solid rgba(176, 68, 50, 0.28);
            border-radius: 8px;
            padding: 0.625rem 0.75rem;
            color: #b04432;
            font-size: 0.8125rem;
            margin-bottom: 1rem;
        }
        button {
            width: 100%;
            padding: 0.75rem;
            background: #1f5b4c;
            border: 1px solid #1f5b4c;
            border-radius: 8px;
            color: white;
            font-size: 0.9375rem;
            font-weight: 500;
            font-family: inherit;
            cursor: pointer;
            min-height: 48px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            transition: background 0.12s, transform 0.08s;
        }
        button:hover { background: #2a6f5e; border-color: #2a6f5e; }
        button:active { transform: scale(0.97); }
        .divider {
            height: 1px;
            background: rgba(26, 24, 21, 0.08);
            margin: 1.375rem -0.25rem 1rem;
        }
        .terminal-link {
            display: flex; align-items: center; justify-content: center; gap: 0.5rem;
            padding: 0.625rem;
            border-radius: 8px;
            background: transparent;
            border: 1px solid rgba(26, 24, 21, 0.16);
            color: #1a1815;
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 500;
        }
        .terminal-link:hover { background: #f0ece2; }
        .terminal-link svg.clock-sm { color: #1f5b4c; }
        .footer {
            margin-top: 1.125rem;
            text-align: center;
            font-size: 0.6875rem;
            color: #8d877d;
            display: flex;
            justify-content: center;
            gap: 0.875rem;
            align-items: center;
        }
        .footer .pill { display: inline-flex; align-items: center; gap: 0.3125rem; }

        @@media (max-width: 480px) {
            .page { padding: 1rem; }
            .wrap { max-width: 100%; }
            .brand-mark { width: 56px; height: 56px; }
            .brand-mark svg { width: 28px; height: 28px; }
            .brand-title { font-size: 1.375rem; }
            .card { padding: 1.25rem; border-radius: 10px; }
            .card-heading { font-size: 1rem; }
            .card-sub { font-size: 0.75rem; }
        }
    </style>
</head>
<body>
<div class="page">
    <div class="wrap">
        <div class="brand-head">
            <div class="brand-mark">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
                </svg>
            </div>
            <h1 class="brand-title">Zeiterfassung Arztpraxis</h1>
            <div class="brand-sub">Arztpraxis Dr. med. Beate Schmitt</div>
        </div>

        <div class="card">
            <h2 class="card-heading">Admin-Anmeldung</h2>
            <p class="card-sub">Nur Administratoren · Mitarbeiter stempeln am Terminal</p>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="error">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 4l9 16H3L12 4z"/><path d="M12 10v4M12 17v.5"/>
                    </svg>
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                @Html.AntiForgeryToken()
                <label for="username">Benutzername</label>
                <input id="username" name="Username" type="text" autocomplete="username"
                       value="@Model.Username" autofocus required />

                <label for="password">Passwort</label>
                <input id="password" name="Password" type="password" autocomplete="current-password" required />

                <button type="submit">
                    Anmelden
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10 6l6 6-6 6"/>
                    </svg>
                </button>
            </form>

            <div class="divider"></div>

            <a class="terminal-link" href="/terminal">
                <svg class="clock-sm" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
                </svg>
                Zum Stempel-Terminal
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10 6l6 6-6 6"/>
                </svg>
            </a>
        </div>

        <div class="footer">
            <span class="pill">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z"/>
                </svg>
                GoBD-konform
            </span>
            <span>·</span>
            <span>v2.4.1</span>
        </div>
    </div>
</div>
</body>
</html>
