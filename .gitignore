## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/

# Rider IDE
.idea/
*.sln.iml

# NuGet Packages
*.nupkg
*.snupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# Database
*.db
*.db-shm
*.db-wal

# Environment
.env
.env.local
appsettings.*.json

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Backup files
*.bak
*.tmp

# Logs
logs/
*.log

# ── Zeiterfassung — local artifacts ───────────────────────────────────────
# Published self-contained binary
publish/
# Local SQLite databases (production + demo + tests)
zeiterfassung.db
zeiterfassung.db-*
zeiterfassung-demo.db
zeiterfassung-demo.db-*
zeiterfassung-test.db
zeiterfassung-test.db-*
src/Zeiterfassung.Web/zeiterfassung*.db
src/Zeiterfassung.Web/zeiterfassung*.db-*
# Verification screenshots (debug artifacts at repo root)
/*.png
# Playwright MCP cache
.playwright-mcp/
# Node deps for the UI test suite
tests/UI/node_modules/
tests/UI/test-results/
tests/UI/playwright-report/
# Design handoff bundle (large; kept locally only)
_design_extract/
