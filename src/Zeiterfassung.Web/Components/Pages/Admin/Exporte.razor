@page "/admin/exporte"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject ZeiterfassungDbContext Db
@inject SaldoService SaldoSvc
@inject IJSRuntime JS

<PageTitle>Exporte — Admin</PageTitle>

<h1>Exporte</h1>
<p class="lead">Monatsberichte für Steuerberater und Lohnabrechnung.</p>

<div class="export-grid">
    <div class="export-card">
        <div class="export-icon pdf">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
        </div>
        <div>
            <div class="export-title">PDF Stundenzettel</div>
            <div class="export-desc">Ein Dokument pro Mitarbeiter, unterschriftsfertig</div>
        </div>
    </div>
    <div class="export-card">
        <div class="export-icon excel">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="8" y1="13" x2="16" y2="13"/>
                <line x1="8" y1="17" x2="16" y2="17"/>
            </svg>
        </div>
        <div>
            <div class="export-title">Excel Sammelbericht</div>
            <div class="export-desc">Alle Mitarbeiter, ein Sheet pro MA + Übersicht</div>
        </div>
    </div>
</div>

<div class="card mt-4">
    <div class="card-body">
        <div class="controls-row">
            <div>
                <label class="form-label">Monat</label>
                <select class="form-select" @bind="_selectedMonth">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m">@(new DateTime(2000, m, 1).ToString("MMMM"))</option>
                    }
                </select>
            </div>
            <div>
                <label class="form-label">Jahr</label>
                <select class="form-select" @bind="_selectedYear">
                    @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                    {
                        <option value="@y">@y</option>
                    }
                </select>
            </div>
            <div>
                <label class="form-label">Praxisname</label>
                <input class="form-control" @bind="_practiceName" placeholder="z.B. Orthopädie Kurdy" />
            </div>
            <div class="controls-buttons">
                <button class="btn btn-outline-secondary" @onclick="LoadPreview" disabled="@_loading">
                    Vorschau
                </button>
                <button class="btn btn-outline-danger" @onclick="DownloadPdf" disabled="@(_preview.Count == 0 || _loading)">
                    PDF
                </button>
                <button class="btn btn-primary" @onclick="DownloadExcel" disabled="@(_preview.Count == 0 || _loading)">
                    Excel
                </button>
            </div>
        </div>
    </div>
</div>

@if (_loading)
{
    <div class="alert alert-info mt-3">
        <span class="spinner-border spinner-border-sm me-2"></span>Daten werden geladen…
    </div>
}

@if (_preview.Count > 0)
{
    <div class="mt-4">
        <div class="preview-header">
            <h2>@(new DateTime(_selectedYear, _selectedMonth, 1).ToString("MMMM yyyy")) — @_preview.Count Mitarbeiter</h2>
        </div>

        <table class="table">
            <thead>
                <tr>
                    <th>Mitarbeiter</th>
                    <th>Ist (h)</th>
                    <th>Soll (h)</th>
                    <th>Saldo (h)</th>
                    <th>Stempelungen</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _preview)
                {
                    <tr>
                        <td>@row.EmployeeName</td>
                        <td style="font-variant-numeric:tabular-nums">@row.TotalWorkedHours.ToString("F1")</td>
                        <td style="font-variant-numeric:tabular-nums">@row.TotalRequiredHours.ToString("F1")</td>
                        <td class="@(row.TotalBalance >= 0 ? "text-success" : "text-danger")"
                            style="font-weight:600;font-variant-numeric:tabular-nums">
                            @(row.TotalBalance >= 0 ? "+" : "")@row.TotalBalance.ToString("F1")
                        </td>
                        <td style="color:#64748b">@row.Days.Sum(d => d.WorkedHours > 0 ? 1 : 0) Tage</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr style="font-weight:600;border-top:2px solid rgba(255,255,255,0.15)">
                    <td>Gesamt</td>
                    <td style="font-variant-numeric:tabular-nums">@_preview.Sum(r => r.TotalWorkedHours).ToString("F1")</td>
                    <td style="font-variant-numeric:tabular-nums">@_preview.Sum(r => r.TotalRequiredHours).ToString("F1")</td>
                    <td class="@(_preview.Sum(r => r.TotalBalance) >= 0 ? "text-success" : "text-danger")"
                        style="font-variant-numeric:tabular-nums">
                        @(_preview.Sum(r => r.TotalBalance) >= 0 ? "+" : "")@_preview.Sum(r => r.TotalBalance).ToString("F1")
                    </td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
}

<style>
    .export-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .export-card { display: flex; align-items: center; gap: 1rem; padding: 1.25rem; background: #1a1d27; border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; }
    .export-icon { width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .export-icon.pdf { background: rgba(248,113,113,0.1); color: #f87171; }
    .export-icon.excel { background: rgba(74,222,128,0.1); color: #4ade80; }
    .export-title { font-weight: 600; color: #e2e8f0; font-size: 0.9rem; }
    .export-desc { font-size: 0.8rem; color: #64748b; margin-top: 0.2rem; }
    .controls-row { display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap; }
    .controls-row > div { min-width: 140px; }
    .controls-buttons { display: flex; gap: 0.5rem; align-items: flex-end; }
    .preview-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }
</style>

@code {
    private int _selectedMonth = DateTime.Now.Month;
    private int _selectedYear = DateTime.Now.Year;
    private string _practiceName = "Arztpraxis";
    private bool _loading;
    private List<Zeiterfassung.Export.MonthReport> _preview = new();

    private async Task LoadPreview()
    {
        _loading = true;
        _preview = new();
        StateHasChanged();

        _preview = await BuildReports();
        _loading = false;
    }

    private async Task<List<Zeiterfassung.Export.MonthReport>> BuildReports()
    {
        var employees = await Db.Employees.Where(e => e.IsActive).OrderBy(e => e.LastName).ToListAsync();
        var monthStart = new DateTime(_selectedYear, _selectedMonth, 1, 0, 0, 0, DateTimeKind.Utc);
        var monthEnd = monthStart.AddMonths(1);
        var holidays = await Db.Holidays.Where(h => h.Date >= monthStart && h.Date < monthEnd).ToListAsync();
        int daysInMonth = DateTime.DaysInMonth(_selectedYear, _selectedMonth);

        var result = new List<Zeiterfassung.Export.MonthReport>();

        foreach (var emp in employees)
        {
            var entries = await Db.TimeEntries
                .Where(e => e.EmployeeId == emp.Id && e.TimestampUtc >= monthStart && e.TimestampUtc < monthEnd)
                .OrderBy(e => e.TimestampUtc)
                .ToListAsync();
            var patterns = await Db.WorkingTimePatterns.Where(p => p.EmployeeId == emp.Id).ToListAsync();

            var report = new Zeiterfassung.Export.MonthReport
            {
                EmployeeName = $"{emp.LastName}, {emp.FirstName}",
                Year = _selectedYear,
                Month = _selectedMonth,
                PracticeName = _practiceName
            };

            for (int day = 1; day <= daysInMonth; day++)
            {
                var dateUtc = new DateTime(_selectedYear, _selectedMonth, day, 0, 0, 0, DateTimeKind.Utc);
                var nextDay = dateUtc.AddDays(1);
                var dayEntries = entries.Where(e => e.TimestampUtc >= dateUtc && e.TimestampUtc < nextDay).OrderBy(e => e.TimestampUtc).ToList();

                var holiday = holidays.FirstOrDefault(h => h.Date.Date == dateUtc.Date);
                var kommenEntry = dayEntries.FirstOrDefault(e => e.Type == TimeEntryType.Kommen);
                var gehenEntry = dayEntries.LastOrDefault(e => e.Type == TimeEntryType.Gehen);

                decimal pause = 0;
                Core.Models.TimeEntry? ps = null;
                foreach (var e in dayEntries)
                {
                    if (e.Type == TimeEntryType.PauseStart) ps = e;
                    else if (e.Type == TimeEntryType.PauseEnd && ps != null)
                    {
                        pause += (decimal)(e.TimestampUtc - ps.TimestampUtc).TotalMinutes;
                        ps = null;
                    }
                }

                decimal worked = 0;
                if (kommenEntry != null && gehenEntry != null)
                    worked = Math.Max(0, (decimal)(gehenEntry.TimestampUtc - kommenEntry.TimestampUtc).TotalHours - pause / 60m);

                var pattern = patterns
                    .Where(p => p.ValidFrom.Date <= dateUtc.Date && (!p.ValidUntil.HasValue || p.ValidUntil.Value.Date >= dateUtc.Date))
                    .OrderByDescending(p => p.ValidFrom).FirstOrDefault();

                decimal required = 0;
                if (holiday == null && dateUtc.DayOfWeek is not DayOfWeek.Saturday and not DayOfWeek.Sunday && pattern != null)
                    required = dateUtc.DayOfWeek switch
                    {
                        DayOfWeek.Monday => pattern.MondayHours,
                        DayOfWeek.Tuesday => pattern.TuesdayHours,
                        DayOfWeek.Wednesday => pattern.WednesdayHours,
                        DayOfWeek.Thursday => pattern.ThursdayHours,
                        DayOfWeek.Friday => pattern.FridayHours,
                        _ => 0
                    };

                report.Days.Add(new Zeiterfassung.Export.DayReport
                {
                    Date = dateUtc.ToLocalTime(),
                    KommenLocal = kommenEntry?.TimestampUtc.ToLocalTime(),
                    GehenLocal = gehenEntry?.TimestampUtc.ToLocalTime(),
                    PauseMinutes = (int)pause,
                    WorkedHours = worked,
                    RequiredHours = required,
                    BalanceHours = worked - required,
                    IsHoliday = holiday != null,
                    HolidayName = holiday?.Name,
                    HasWarning = worked > 10 || (worked > 6 && pause < 30)
                });
            }

            result.Add(report);
        }

        return result;
    }

    private async Task DownloadExcel()
    {
        if (_preview.Count == 0) return;
        var bytes = Zeiterfassung.Export.ExcelMonatsbericht.Generate(_preview);
        var fileName = $"Zeiterfassung_{_selectedYear}_{_selectedMonth:D2}.xlsx";
        await JS.InvokeVoidAsync("downloadFile", fileName, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", bytes);
    }

    private async Task DownloadPdf()
    {
        if (_preview.Count == 0 || _preview[0] == null) return;
        // PDF: one download per employee — generate zip or first employee as demo
        var bytes = Zeiterfassung.Export.PdfStundenzettelReport.Generate(_preview[0]);
        var fileName = $"Stundenzettel_{_preview[0].EmployeeName.Replace(", ", "_")}_{_selectedYear}_{_selectedMonth:D2}.pdf";
        await JS.InvokeVoidAsync("downloadFile", fileName, "application/pdf", bytes);
    }
}
