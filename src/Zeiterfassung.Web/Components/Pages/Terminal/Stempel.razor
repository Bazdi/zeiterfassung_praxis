@page "/terminal"
@page "/terminal/stempel"
@layout TerminalLayout
@rendermode InteractiveServer
@inject ZeiterfassungDbContext Db
@inject PinAuthenticationService PinAuth
@inject StempelManager StempelMgr
@inject ITimeEntryRepository TimeEntryRepo

<PageTitle>Zeiterfassung — Terminal</PageTitle>

<div class="terminal-container">

    @if (_phase == Phase.SelectEmployee)
    {
        <div class="terminal-header" style="width:100%;max-width:1200px;">
            <div class="terminal-brand">
                <div class="terminal-brand-mark">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
                    </svg>
                </div>
                <div>
                    <div class="terminal-brand-title">Zeiterfassung</div>
                    <div class="terminal-brand-sub">Arztpraxis Dr. Schmitt · Terminal am Empfang</div>
                </div>
            </div>
            <div class="terminal-clock">
                <div class="terminal-time">@_now.ToString("HH:mm")</div>
                <div class="terminal-date">@_now.ToString("dddd · dd. MMMM yyyy", new System.Globalization.CultureInfo("de-DE"))</div>
            </div>
        </div>

        <p class="terminal-subtitle" style="width:100%;max-width:1200px;">Bitte auf Ihren Namen tippen</p>

        <div class="employee-grid">
            @foreach (var emp in _employees)
            {
                var status = _employeeStatus.GetValueOrDefault(emp.Id, EmployeeStatus.None);
                var initials = (emp.FirstName.Length > 0 ? emp.FirstName[0].ToString() : "") +
                               (emp.LastName.Length > 0  ? emp.LastName[0].ToString()  : "");
                <button class="emp-btn emp-status-@status.ToString().ToLower()"
                        @onclick="() => SelectEmployee(emp)">
                    <div class="emp-name-row">
                        <div class="emp-avatar">@initials.ToUpper()</div>
                        <div class="emp-name-text">
                            <div class="emp-first">@emp.FirstName</div>
                            <div class="emp-last">@emp.LastName</div>
                        </div>
                    </div>
                    <div class="emp-status-row">
                        @if (status == EmployeeStatus.Anwesend)
                        {
                            <span class="emp-status-badge status-anwesend">
                                <span class="emp-status-badge-dot"></span>Anwesend
                            </span>
                        }
                        else if (status == EmployeeStatus.InPause)
                        {
                            <span class="emp-status-badge status-inpause">
                                <span class="emp-status-badge-dot"></span>Pause
                            </span>
                        }
                        else if (status == EmployeeStatus.Gegangen)
                        {
                            <span class="emp-status-badge status-gegangen">
                                <span class="emp-status-badge-dot"></span>Gegangen
                            </span>
                        }
                        else
                        {
                            <span class="emp-status-badge status-none">Nicht gestempelt</span>
                        }
                        <svg class="emp-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M10 6l6 6-6 6"/>
                        </svg>
                    </div>
                </button>
            }
        </div>

        <div class="terminal-footer">
            <span>v2.4.1 · GoBD-konform · letzte Synchronisation @_now.ToString("HH:mm")</span>
            <span class="terminal-online">
                <span class="terminal-online-dot"></span>System online
            </span>
        </div>
    }

    @if (_phase == Phase.EnterPin)
    {
        var initials2 = (_selectedEmployee!.FirstName.Length > 0 ? _selectedEmployee.FirstName[0].ToString() : "") +
                        (_selectedEmployee.LastName.Length > 0  ? _selectedEmployee.LastName[0].ToString()  : "");
        <div class="pin-container">
            <div class="pin-left">
                <button class="btn-cancel" style="margin-top:0;margin-bottom:2rem;" @onclick="Cancel">
                    ← Zurück
                </button>
                <div class="pin-avatar">@initials2.ToUpper()</div>
                <h2>@_selectedEmployee.FirstName @_selectedEmployee.LastName</h2>
                <p class="pin-status">
                    Aktueller Status:
                    <span class="pin-status-value-@_currentStatus.ToString().ToLower()">
                        @GetStatusLabel(_currentStatus)
                    </span>
                </p>
                @if (_errorMessage != null)
                {
                    <div class="pin-message error">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
                            <path d="M12 4l9 16H3L12 4z"/><path d="M12 10v4M12 17v.5"/>
                        </svg>
                        @_errorMessage
                    </div>
                }
                else
                {
                    <div class="pin-message info">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
                            <path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z"/>
                        </svg>
                        PIN eingeben zum Stempeln. Nach 3 Fehlversuchen wird das Konto gesperrt.
                    </div>
                }
            </div>

            <div class="pin-right">
                <div class="pin-dots">
                    @for (int i = 0; i < 6; i++)
                    {
                        <div class="pin-dot @(i < _pinInput.Length ? "filled" : "")"></div>
                    }
                </div>
                <div class="numpad">
                    @foreach (var digit in new[] { "1","2","3","4","5","6","7","8","9","←","0","✓" })
                    {
                        <button class="numpad-btn @(digit == "✓" ? "numpad-confirm" : digit == "←" ? "numpad-back" : "")"
                                @onclick="() => NumpadPressed(digit)"
                                disabled="@(_pinInput.Length == 6 && digit != "✓" && digit != "←")">
                            @digit
                        </button>
                    }
                </div>
            </div>
        </div>
    }

    @if (_phase == Phase.SelectAction)
    {
        var initials3 = (_selectedEmployee!.FirstName.Length > 0 ? _selectedEmployee.FirstName[0].ToString() : "") +
                        (_selectedEmployee.LastName.Length > 0  ? _selectedEmployee.LastName[0].ToString()  : "");
        <div class="action-container">
            <button class="btn-cancel" style="align-self:flex-start;margin-bottom:1.375rem;" @onclick="Cancel">← Zurück</button>

            <div class="emp-card">
                <div class="emp-card-avatar">@initials3.ToUpper()</div>
                <div>
                    <div class="emp-card-name">@_selectedEmployee.FirstName @_selectedEmployee.LastName</div>
                    <div class="emp-card-meta">
                        Status: <strong>@GetStatusLabel(_currentStatus)</strong>
                    </div>
                </div>
            </div>

            @if (_lastAction != null)
            {
                <div class="success-badge">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12l5 5 9-10"/>
                    </svg>
                    @_lastAction — @_lastActionTime!.Value.ToLocalTime().ToString("HH:mm:ss")
                </div>
            }

            @if (_warnings.Count > 0)
            {
                <div class="arbzg-warnings">
                    @foreach (var w in _warnings)
                    {
                        <div class="warning @w.Severity.ToString().ToLower()">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px">
                                <path d="M12 4l9 16H3L12 4z"/><path d="M12 10v4M12 17v.5"/>
                            </svg>
                            <div><strong>ArbZG · </strong>@w.Message</div>
                        </div>
                    }
                </div>
            }

            <div class="action-grid">
                @if (_currentStatus == EmployeeStatus.None || _currentStatus == EmployeeStatus.Gegangen)
                {
                    <button class="action-btn action-kommen" @onclick="() => DoStempel(TimeEntryType.Kommen)">
                        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 5l12 7-12 7V5z"/></svg>
                        <div class="action-btn-label">
                            KOMMEN
                            <div class="action-btn-sub">Arbeitsbeginn stempeln</div>
                        </div>
                    </button>
                }
                @if (_currentStatus == EmployeeStatus.Anwesend)
                {
                    <button class="action-btn action-pause" @onclick="() => DoStempel(TimeEntryType.PauseStart)">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="5" width="4" height="14" rx="1"/><rect x="14" y="5" width="4" height="14" rx="1"/></svg>
                        <div class="action-btn-label">
                            PAUSE START
                            <div class="action-btn-sub">Pause beginnen</div>
                        </div>
                    </button>
                    <button class="action-btn action-gehen" @onclick="() => DoStempel(TimeEntryType.Gehen)">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 4h4a1 1 0 011 1v14a1 1 0 01-1 1h-4"/><path d="M10 17l5-5-5-5"/><path d="M15 12H3"/></svg>
                        <div class="action-btn-label">
                            GEHEN
                            <div class="action-btn-sub">Arbeitsende stempeln</div>
                        </div>
                    </button>
                }
                @if (_currentStatus == EmployeeStatus.InPause)
                {
                    <button class="action-btn action-pause-end" @onclick="() => DoStempel(TimeEntryType.PauseEnd)">
                        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 5l12 7-12 7V5z"/></svg>
                        <div class="action-btn-label">
                            PAUSE ENDE
                            <div class="action-btn-sub">Arbeit fortsetzen</div>
                        </div>
                    </button>
                }
            </div>

            <div style="margin-top:auto;padding-top:1.375rem;text-align:center;font-size:0.75rem;color:#8d877d;">
                Stempelung wird sofort und manipulationssicher protokolliert · Auto-Logout in 30s
            </div>
        </div>
    }

    @if (_phase == Phase.Confirmed)
    {
        <div class="confirmed-container">
            <div class="confirmed-icon">✓</div>
            <div class="confirmed-welcome">Willkommen,</div>
            <div class="confirmed-name">@_selectedEmployee!.FirstName @_selectedEmployee.LastName</div>
            <div class="confirmed-details">
                <div>
                    <div class="confirmed-detail-label">Aktion</div>
                    <div class="confirmed-detail-value green">@_lastAction gestempelt</div>
                </div>
                <div class="confirmed-divider"></div>
                <div>
                    <div class="confirmed-detail-label">Zeitstempel</div>
                    <div class="confirmed-detail-value">@_lastActionTime!.Value.ToLocalTime().ToString("dd.MM.yyyy · HH:mm:ss")</div>
                </div>
            </div>
            <div class="auto-logout-countdown">
                <svg width="24" height="24" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10" fill="none" stroke="rgba(26,24,21,0.12)" stroke-width="2.5"/>
                    <circle cx="12" cy="12" r="10" fill="none" stroke="#1f5b4c" stroke-width="2.5"
                            stroke-dasharray="62.83" stroke-dashoffset="@(62.83 * (1 - _countdownSeconds / 5.0))" stroke-linecap="round"
                            transform="rotate(-90 12 12)"/>
                </svg>
                Auto-Logout in <strong>@_countdownSeconds s</strong>
            </div>
        </div>
    }

</div>

<style>
/* ── Terminal / Kiosk — warm paper, sage accent ── */
.terminal-container {
    min-height: 100vh;
    background: #f4f1ea;
    color: #1a1815;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    padding: 3rem 3.5rem 2.25rem;
    position: relative;
}

/* Header: brand left, clock right */
.terminal-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    max-width: 1200px;
    margin-bottom: 2rem;
    gap: 2rem;
}

.terminal-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.terminal-brand-mark {
    width: 44px; height: 44px;
    border-radius: 10px;
    background: #1f5b4c;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}

.terminal-brand-title { font-size: 1.625rem; font-weight: 600; letter-spacing: -0.025em; color: #1a1815; line-height: 1.15; }
.terminal-brand-sub  { font-size: 0.875rem; color: #5a544c; margin-top: 0.1875rem; }

.terminal-clock {
    text-align: right;
}

.terminal-time {
    font-size: 8.25rem;
    font-weight: 500;
    letter-spacing: -0.04em;
    color: #1a1815;
    line-height: 0.95;
    font-variant-numeric: tabular-nums;
}

.terminal-date { font-size: 0.9375rem; color: #5a544c; margin-top: 0.5rem; }

.terminal-subtitle {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #8d877d;
    margin-bottom: 1rem;
    align-self: flex-start;
    width: 100%;
    max-width: 1200px;
}

/* Footer */
.terminal-footer {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 1rem 3.5rem;
    border-top: 1px solid rgba(26,24,21,0.08);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    color: #8d877d;
}

.terminal-online {
    display: flex; align-items: center; gap: 0.5rem;
    color: #2f7a5c;
}

.terminal-online-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #2f7a5c;
}

/* Employee grid */
.employee-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.125rem;
    width: 100%;
    max-width: 1200px;
    align-content: start;
    flex: 1;
}

.emp-btn {
    padding: 1.5rem 1.375rem;
    border-radius: 14px;
    background: #fff;
    border: 1px solid rgba(26,24,21,0.08);
    border-left: 4px solid rgba(26,24,21,0.08);
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    transition: transform 0.1s ease, border-color 0.1s;
    min-height: 168px;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
}
.emp-btn:hover { transform: translateY(-1px); border-color: rgba(26,24,21,0.15); }
.emp-btn:active { transform: scale(0.98); }

.emp-btn.emp-status-anwesend { border-left-color: #2f7a5c; }
.emp-btn.emp-status-inpause  { border-left-color: #9a6b14; }
.emp-btn.emp-status-gegangen { border-left-color: #76706a; }

.emp-avatar {
    width: 56px; height: 56px;
    border-radius: 28px;
    background: #faf7f0;
    border: 1px solid rgba(26,24,21,0.12);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1875rem; font-weight: 600;
    color: #1f5b4c;
    letter-spacing: 0.03em;
}

.emp-name-row {
    display: flex;
    align-items: center;
    gap: 0.875rem;
}

.emp-name-text { flex: 1; }
.emp-first { font-size: 0.875rem; color: #5a544c; font-weight: 500; }
.emp-last  { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.025em; color: #1a1815; line-height: 1.1; }

.emp-status-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
}

.emp-status-badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 5px 11px;
    border-radius: 7px;
    font-size: 0.78125rem; font-weight: 500;
}
.emp-status-badge-dot {
    width: 6px; height: 6px; border-radius: 3px;
}

.emp-status-badge.status-anwesend { background: #e6f0ea; color: #2f7a5c; border: 1px solid rgba(47,122,92,0.28); }
.emp-status-badge.status-anwesend .emp-status-badge-dot { background: #2f7a5c; }
.emp-status-badge.status-inpause  { background: #fbf2dc; color: #9a6b14; border: 1px solid rgba(154,107,20,0.28); }
.emp-status-badge.status-inpause  .emp-status-badge-dot { background: #9a6b14; }
.emp-status-badge.status-gegangen { background: #ece8df; color: #76706a; border: 1px solid rgba(118,112,106,0.28); }
.emp-status-badge.status-gegangen .emp-status-badge-dot { background: #76706a; }
.emp-status-badge.status-none { font-size: 0.78125rem; color: #8d877d; background: none; border: none; padding: 5px 0; }

.emp-arrow { color: #8d877d; }

/* PIN entry */
.pin-container {
    display: grid;
    grid-template-columns: 1fr 440px;
    gap: 3.5rem;
    align-items: center;
    max-width: 1200px;
    width: 100%;
    flex: 1;
}

.pin-left { }
.pin-left h2 { font-size: 2.375rem; font-weight: 600; letter-spacing: -0.04em; margin: 0 0 0.5rem; }
.pin-status { font-size: 0.9375rem; color: #5a544c; margin-bottom: 2rem; }
.pin-status-value-anwesend { color: #2f7a5c; font-weight: 500; }
.pin-status-value-inpause  { color: #9a6b14; font-weight: 500; }

.pin-avatar {
    width: 88px; height: 88px;
    border-radius: 44px;
    background: #fff;
    border: 1px solid rgba(26,24,21,0.12);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.75rem; font-weight: 600;
    color: #1f5b4c;
    margin-bottom: 1.375rem;
}

.pin-message {
    display: flex; align-items: flex-start; gap: 0.625rem;
    padding: 0.875rem 1.125rem;
    border-radius: 10px;
    font-size: 0.84375rem; line-height: 1.5;
    max-width: 480px;
}
.pin-message.info   { background: #fff; border: 1px solid rgba(26,24,21,0.08); color: #5a544c; }
.pin-message.error  { background: #fbe9e4; border: 1px solid rgba(176,68,50,0.28); color: #b04432; }
.pin-message.locked { background: #fbe9e4; border: 1px solid rgba(176,68,50,0.28); color: #b04432; }

.pin-right { }

.pin-dots {
    display: flex;
    justify-content: center;
    gap: 0.875rem;
    margin-bottom: 2rem;
}

.pin-dot {
    width: 18px; height: 18px;
    border-radius: 9px;
    border: 2px solid rgba(26,24,21,0.16);
    background: transparent;
    transition: background 0.15s, border-color 0.15s;
}
.pin-dot.filled { background: #1f5b4c; border-color: #1f5b4c; }

.numpad {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
}

.numpad-btn {
    padding: 0;
    min-height: 80px;
    font-size: 1.75rem;
    font-weight: 500;
    border-radius: 14px;
    cursor: pointer;
    font-family: 'Segoe UI', Georgia, serif;
    font-variant-numeric: tabular-nums;
    transition: transform 0.08s, background 0.1s;
    display: flex; align-items: center; justify-content: center;
    background: #fff;
    color: #1a1815;
    border: 1px solid rgba(26,24,21,0.12);
}
.numpad-btn:hover:not(:disabled) { background: #faf7f0; }
.numpad-btn:active:not(:disabled) { transform: scale(0.96); }
.numpad-btn:disabled { opacity: 0.35; cursor: not-allowed; }

.numpad-confirm {
    background: #1f5b4c !important;
    border-color: #1f5b4c !important;
    color: #fff !important;
}
.numpad-confirm:hover:not(:disabled) { background: #2a6f5e !important; }

.numpad-back {
    color: #b04432 !important;
}

.btn-cancel {
    background: transparent;
    border: 1px solid rgba(26,24,21,0.12);
    color: #5a544c;
    padding: 0.625rem 1.5rem;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.875rem;
    margin-top: 1.25rem;
    transition: background 0.1s, color 0.1s;
}
.btn-cancel:hover { background: #f0ece2; color: #1a1815; }

/* Action screen */
.action-container {
    width: 100%;
    max-width: 880px;
    display: flex;
    flex-direction: column;
    flex: 1;
}

.emp-card {
    background: #fff;
    border: 1px solid rgba(26,24,21,0.08);
    border-radius: 12px;
    padding: 1.375rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.125rem;
}

.emp-card-avatar {
    width: 64px; height: 64px;
    border-radius: 32px;
    background: #faf7f0;
    border: 1px solid rgba(26,24,21,0.12);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.375rem; font-weight: 600;
    color: #1f5b4c;
}

.emp-card-name { font-size: 1.625rem; font-weight: 600; letter-spacing: -0.025em; margin-bottom: 0.375rem; }
.emp-card-meta { font-size: 0.875rem; color: #5a544c; }
.emp-card-meta strong { font-weight: 500; }

.arbzg-warnings { margin-bottom: 1.125rem; }
.warning {
    display: flex; align-items: flex-start; gap: 0.75rem;
    padding: 0.875rem 1.125rem;
    border-radius: 12px;
    margin-bottom: 0.5rem;
    font-size: 0.875rem; line-height: 1.5;
}
.warning.high   { background: #fbe9e4; border: 1px solid rgba(176,68,50,0.28); color: #b04432; }
.warning.medium { background: #fbf2dc; border: 1px solid rgba(154,107,20,0.28); color: #9a6b14; }

.action-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.875rem;
    margin-bottom: 1rem;
}

.action-btn {
    min-height: 116px;
    padding: 0 2rem;
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    border: none;
    border-radius: 14px;
    cursor: pointer;
    font-family: inherit;
    display: flex; align-items: center; justify-content: center; gap: 1.125rem;
    transition: filter 0.1s, transform 0.08s;
    color: #fff;
}
.action-btn:hover  { filter: brightness(1.06); }
.action-btn:active { transform: scale(0.97); }

.action-btn-sub { font-size: 0.8125rem; font-weight: 400; opacity: 0.85; margin-top: 0.25rem; text-align: left; }
.action-btn-label { text-align: left; }

.action-kommen   { background: #2f7a5c; grid-column: 1 / -1; }
.action-pause    { background: #c08a1a; }
.action-pause-end{ background: #1f5b4c; grid-column: 1 / -1; }
.action-gehen    { background: #b04432; }

.success-badge {
    display: flex; align-items: center; gap: 0.625rem;
    background: #e6f0ea;
    border: 1px solid rgba(47,122,92,0.28);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
    font-size: 0.9375rem; color: #2f7a5c; font-weight: 500;
}

/* Confirmation screen */
.confirmed-container {
    text-align: center;
    max-width: 540px;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.confirmed-icon {
    width: 96px; height: 96px;
    border-radius: 48px;
    background: #1f5b4c;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.75rem;
    font-size: 2.5rem;
    color: #fff;
}

.confirmed-welcome { font-size: 1.375rem; color: #5a544c; font-weight: 400; margin-bottom: 0.25rem; }
.confirmed-name {
    font-size: 3rem; font-weight: 600; letter-spacing: -0.04em;
    color: #1a1815; margin-bottom: 1.75rem;
}

.confirmed-details {
    background: #fff;
    border: 1px solid rgba(26,24,21,0.08);
    border-radius: 12px;
    padding: 1.25rem 1.75rem;
    display: inline-flex;
    align-items: center;
    gap: 1.75rem;
    margin-bottom: 1.75rem;
}

.confirmed-detail-label {
    font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.07em;
    text-transform: uppercase; color: #8d877d; margin-bottom: 0.1875rem;
}
.confirmed-detail-value { font-size: 1.0625rem; font-weight: 600; }
.confirmed-detail-value.green { color: #2f7a5c; }

.confirmed-divider { width: 1px; height: 36px; background: rgba(26,24,21,0.08); }

.auto-logout-countdown {
    display: flex; align-items: center; gap: 0.75rem;
    font-size: 0.875rem; color: #5a544c;
}

/* ─── Responsive ───────────────────────────────────────── */

/* Fluid scaling for hero typography */
.terminal-time { font-size: clamp(3.25rem, 11vw, 8.25rem); }
.terminal-container { padding: clamp(1rem, 4vw, 3rem) clamp(1rem, 4vw, 3.5rem) clamp(3.5rem, 5vw, 2.25rem); }
.confirmed-name { font-size: clamp(2rem, 5vw, 3rem); }

/* Tablet — 2-col employee grid */
@@media (max-width: 1023px) {
    .employee-grid { grid-template-columns: repeat(2, 1fr); }
    .pin-container { grid-template-columns: 1fr 360px; gap: 2.5rem; }
    .terminal-header { gap: 1.5rem; }
}

/* Tablet portrait & smaller — stack PIN screen */
@@media (max-width: 820px) {
    .pin-container {
        grid-template-columns: 1fr;
        gap: 2rem;
        max-width: 480px;
        margin: 0 auto;
    }
    .pin-left { text-align: center; }
    .pin-avatar { margin-left: auto; margin-right: auto; }
    .pin-message { margin-left: auto; margin-right: auto; }
}

/* Phone */
@@media (max-width: 640px) {
    .employee-grid { grid-template-columns: 1fr; gap: 0.75rem; }
    .terminal-header {
        flex-direction: column;
        align-items: flex-start;
        margin-bottom: 1.5rem;
    }
    .terminal-clock { text-align: left; align-self: stretch; }
    .terminal-time { line-height: 0.9; }
    .terminal-subtitle { margin-bottom: 0.75rem; font-size: 0.625rem; }

    .emp-btn { min-height: 110px; padding: 1.125rem 1rem; }
    .emp-avatar { width: 48px; height: 48px; font-size: 1rem; }
    .emp-last { font-size: 1.25rem; }
    .emp-first { font-size: 0.8125rem; }

    .terminal-footer {
        padding: 0.75rem 1rem;
        flex-direction: column;
        gap: 0.25rem;
        align-items: flex-start;
    }

    .pin-left h2 { font-size: 1.75rem; }
    .pin-status { font-size: 0.875rem; margin-bottom: 1.25rem; }
    .pin-avatar { width: 72px; height: 72px; font-size: 1.5rem; margin-bottom: 1rem; }
    .pin-dots { gap: 0.625rem; margin-bottom: 1.25rem; }
    .pin-dot { width: 16px; height: 16px; }
    .numpad { gap: 0.5rem; }
    .numpad-btn { min-height: 62px; font-size: 1.5rem; border-radius: 12px; }

    .emp-card { padding: 1rem; gap: 1rem; }
    .emp-card-avatar { width: 52px; height: 52px; font-size: 1.125rem; }
    .emp-card-name { font-size: 1.25rem; }
    .emp-card-meta { font-size: 0.8125rem; }

    .action-grid { grid-template-columns: 1fr !important; gap: 0.625rem; }
    .action-btn {
        min-height: 84px;
        padding: 0 1.25rem;
        font-size: 1.125rem;
        gap: 0.875rem;
        border-radius: 12px;
    }
    .action-btn-sub { font-size: 0.75rem; margin-top: 2px; }

    .confirmed-icon { width: 72px; height: 72px; border-radius: 36px; margin-bottom: 1.25rem; }
    .confirmed-welcome { font-size: 1.125rem; }
    .confirmed-details {
        flex-direction: column;
        gap: 0.875rem;
        padding: 1rem 1.25rem;
        align-items: stretch;
    }
    .confirmed-divider { width: 100%; height: 1px; }
    .confirmed-detail-value { font-size: 1rem; }
}
</style>

@code {
    private enum Phase { SelectEmployee, EnterPin, SelectAction, Confirmed }
    private enum EmployeeStatus { None, Anwesend, InPause, Gegangen }

    private Phase _phase = Phase.SelectEmployee;
    private List<Employee> _employees = new();
    private Dictionary<int, EmployeeStatus> _employeeStatus = new();
    private Employee? _selectedEmployee;
    private string _pinInput = "";
    private string? _errorMessage;
    private EmployeeStatus _currentStatus;
    private string? _lastAction;
    private DateTime? _lastActionTime;
    private List<ValidationWarning> _warnings = new();
    private int _countdownSeconds = 5;
    private DateTime _now = DateTime.Now;
    private System.Timers.Timer? _clockTimer;
    private System.Timers.Timer? _logoutTimer;

    protected override async Task OnInitializedAsync()
    {
        _employees = await Db.Employees
            .Where(e => e.IsActive)
            .OrderBy(e => e.LastName)
            .ThenBy(e => e.FirstName)
            .ToListAsync();

        await RefreshStatusAsync();

        _clockTimer = new System.Timers.Timer(1000);
        _clockTimer.Elapsed += (_, _) => { _now = DateTime.Now; InvokeAsync(StateHasChanged); };
        _clockTimer.Start();
    }

    private async Task RefreshStatusAsync()
    {
        var today = DateTime.UtcNow.Date;
        foreach (var emp in _employees)
        {
            var last = await Db.TimeEntries
                .Where(e => e.EmployeeId == emp.Id && e.TimestampUtc >= today)
                .OrderByDescending(e => e.TimestampUtc)
                .FirstOrDefaultAsync();

            _employeeStatus[emp.Id] = last?.Type switch
            {
                TimeEntryType.Kommen => EmployeeStatus.Anwesend,
                TimeEntryType.PauseStart => EmployeeStatus.InPause,
                TimeEntryType.PauseEnd => EmployeeStatus.Anwesend,
                TimeEntryType.Gehen => EmployeeStatus.Gegangen,
                _ => EmployeeStatus.None
            };
        }
    }

    private void SelectEmployee(Employee emp)
    {
        _selectedEmployee = emp;
        _pinInput = "";
        _errorMessage = null;
        _phase = Phase.EnterPin;
    }

    private void NumpadPressed(string key)
    {
        if (key == "←")
        {
            if (_pinInput.Length > 0)
                _pinInput = _pinInput[..^1];
            _errorMessage = null;
        }
        else if (key == "✓")
        {
            _ = ValidatePinAsync();
        }
        else if (_pinInput.Length < 6)
        {
            _pinInput += key;
            if (_pinInput.Length == 6)
                _ = ValidatePinAsync();
        }
    }

    private async Task ValidatePinAsync()
    {
        if (_selectedEmployee == null || _pinInput.Length != 6)
            return;

        var emp = await Db.Employees.FindAsync(_selectedEmployee.Id);
        if (emp == null) { Cancel(); return; }

        var result = PinAuth.Authenticate(emp, _pinInput);
        await Db.SaveChangesAsync();

        if (!result.Success)
        {
            _pinInput = "";
            if (result.RequiresAdminReset)
                _errorMessage = "Account gesperrt. Bitte Admin kontaktieren.";
            else if (result.LockoutRemainingSeconds.HasValue)
                _errorMessage = $"Gesperrt für {result.LockoutRemainingSeconds}s.";
            else
                _errorMessage = $"Falsche PIN. {result.RemainingAttempts} Versuche übrig.";
            return;
        }

        _currentStatus = _employeeStatus.GetValueOrDefault(emp.Id, EmployeeStatus.None);
        _lastAction = null;
        _warnings = new();
        _phase = Phase.SelectAction;
    }

    private async Task DoStempel(TimeEntryType type)
    {
        if (_selectedEmployee == null) return;

        try
        {
            var request = new StempelRequest
            {
                EmployeeId = _selectedEmployee.Id,
                Type = type,
                Source = EntrySource.Terminal
            };

            // StempelManager handles all saves internally (two-phase: insert→get ID→hash→update)
            var result = await StempelMgr.StempelAsync(request, TimeEntryRepo);

            _lastAction = type switch
            {
                TimeEntryType.Kommen => "Kommen",
                TimeEntryType.Gehen => "Gehen",
                TimeEntryType.PauseStart => "Pause Start",
                TimeEntryType.PauseEnd => "Pause Ende",
                _ => type.ToString()
            };
            _lastActionTime = result.Entry.TimestampUtc;
            _warnings = result.Warnings.ToList();
            _countdownSeconds = 5;
            _phase = Phase.Confirmed;

            StartLogoutTimer();
            await RefreshStatusAsync();
        }
        catch (StempelException ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void StartLogoutTimer()
    {
        _logoutTimer?.Dispose();
        _logoutTimer = new System.Timers.Timer(1000);
        _logoutTimer.Elapsed += (_, _) =>
        {
            _countdownSeconds--;
            if (_countdownSeconds <= 0)
            {
                _logoutTimer?.Dispose();
                InvokeAsync(Reset);
            }
            InvokeAsync(StateHasChanged);
        };
        _logoutTimer.Start();
    }

    private void Reset()
    {
        _phase = Phase.SelectEmployee;
        _selectedEmployee = null;
        _pinInput = "";
        _errorMessage = null;
        _lastAction = null;
        _lastActionTime = null;
        _warnings = new();
        _logoutTimer?.Dispose();
        _ = RefreshStatusAsync();
    }

    private void Cancel() => Reset();

    private string GetStatusLabel(EmployeeStatus status) => status switch
    {
        EmployeeStatus.Anwesend => "Anwesend",
        EmployeeStatus.InPause => "Pause",
        EmployeeStatus.Gegangen => "Gegangen",
        _ => "Heute noch nicht gestempelt"
    };

    public void Dispose()
    {
        _clockTimer?.Dispose();
        _logoutTimer?.Dispose();
    }
}
