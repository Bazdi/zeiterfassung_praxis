@inherits LayoutComponentBase
@inject Zeiterfassung.Web.Services.DemoModeOptions DemoOpts

@if (DemoOpts.Enabled)
{
    <div style="position:fixed;top:0;left:0;right:0;z-index:80;height:36px;
                display:flex;align-items:center;gap:0.75rem;padding:0 1rem;
                background:#fbf2dc;border-bottom:1px solid rgba(154,107,20,0.28);
                color:#9a6b14;font-size:0.75rem;font-family:'Segoe UI',system-ui,sans-serif;">
        <span style="width:7px;height:7px;border-radius:50%;background:#9a6b14;"></span>
        <strong style="font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-size:0.6875rem">DEMO-MODUS</strong>
        <span style="opacity:0.8">PINs: 100001–100006 · setzt sich beim Neustart zurück</span>
    </div>
    <div style="height:36px"></div>
}

@Body

<div id="blazor-error-ui" style="display:none;position:fixed;bottom:0;left:0;right:0;padding:1rem;background:#fbe9e4;border-top:1px solid rgba(176,68,50,0.28);color:#b04432;z-index:9999;">
    Verbindungsfehler.
    <a href="" style="color:#b04432;text-decoration:underline;margin-left:1rem;font-weight:600;">Neu laden</a>
</div>
