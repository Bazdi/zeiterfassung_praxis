@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<div class="nav-brand">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
    </svg>
    Zeiterfassung
</div>

<nav class="nav-section">
    <span class="nav-label">Terminal</span>
    <NavLink class="nav-link" href="terminal" Match="NavLinkMatch.All">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
        </svg>
        Stempeln
    </NavLink>
</nav>

<nav class="nav-section">
    <span class="nav-label">Mitarbeiter</span>
    <NavLink class="nav-link" href="selfservice">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Meine Zeiten
    </NavLink>
</nav>

<AuthorizeView Roles="Admin">
    <Authorized>
        <nav class="nav-section">
            <span class="nav-label">Administration</span>
            <NavLink class="nav-link" href="admin/mitarbeiter">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                Mitarbeiter
            </NavLink>
            <NavLink class="nav-link" href="admin/korrekturen">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Korrekturen
            </NavLink>
            <NavLink class="nav-link" href="admin/exporte">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Exporte
            </NavLink>
            <NavLink class="nav-link" href="admin/integritaet">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                Integritätsprüfung
            </NavLink>
        </nav>
    </Authorized>
</AuthorizeView>

<div class="nav-spacer"></div>

<AuthorizeView>
    <Authorized>
        <div class="nav-user">
            <div class="nav-user-info">
                <span class="nav-user-name">@context.User.Identity?.Name</span>
                <span class="nav-user-role">Administrator</span>
            </div>
            <a href="/logout" class="nav-logout" title="Abmelden">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
            </a>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="nav-login-hint">
            <a href="/login" class="nav-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                    <polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/>
                </svg>
                Admin-Login
            </a>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    :host, .nav-brand, .nav-section, .nav-link, .nav-label,
    .nav-user, .nav-login-hint, .nav-spacer { all: revert; }

    .nav-brand {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 1.25rem 1rem 1rem;
        font-size: 0.9rem;
        font-weight: 600;
        color: #e2e8f0;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        margin-bottom: 0.5rem;
    }

    .nav-section {
        padding: 0.5rem 0.5rem 0.25rem;
    }

    .nav-label {
        display: block;
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #64748b;
        padding: 0.25rem 0.5rem 0.4rem;
    }

    .nav-link {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.55rem 0.75rem;
        border-radius: 8px;
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 450;
        min-height: 40px;
        transition: background 0.12s ease, color 0.12s ease;
        margin-bottom: 2px;
        width: 100%;
        box-sizing: border-box;
    }

    .nav-link:hover { background: rgba(255,255,255,0.07); color: #e2e8f0; }
    .nav-link.active { background: rgba(79,142,247,0.15); color: #6aa3ff; font-weight: 500; }
    .nav-link svg { flex-shrink: 0; opacity: 0.7; }
    .nav-link.active svg { opacity: 1; }

    .nav-spacer { flex: 1; }

    .nav-user {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 0.875rem;
        border-top: 1px solid rgba(255,255,255,0.08);
        margin-top: auto;
    }

    .nav-user-info { flex: 1; overflow: hidden; }
    .nav-user-name { display: block; font-size: 0.8rem; font-weight: 600; color: #e2e8f0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .nav-user-role { display: block; font-size: 0.7rem; color: #64748b; }

    .nav-logout {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px; height: 32px;
        border-radius: 8px;
        color: #64748b;
        text-decoration: none;
        flex-shrink: 0;
        transition: background 0.12s, color 0.12s;
    }
    .nav-logout:hover { background: rgba(248,113,113,0.15); color: #f87171; }

    .nav-login-hint {
        padding: 0.5rem;
        border-top: 1px solid rgba(255,255,255,0.08);
    }
</style>
