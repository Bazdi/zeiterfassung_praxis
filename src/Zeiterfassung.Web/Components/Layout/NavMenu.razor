@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<div class="nav-brand">
    <div class="nav-brand-mark">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
        </svg>
    </div>
    <div>
        <div class="nav-brand-title">Zeiterfassung</div>
        <div class="nav-brand-sub">Arztpraxis · Hamburg</div>
    </div>
</div>

<nav class="nav-section">
    <span class="nav-label">Terminal</span>
    <NavLink class="nav-link" href="terminal" Match="NavLinkMatch.All">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
        </svg>
        Stempeln
    </NavLink>
</nav>

<nav class="nav-section">
    <span class="nav-label">Mitarbeiter</span>
    <NavLink class="nav-link" href="selfservice" Match="NavLinkMatch.All">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Meine Zeiten
    </NavLink>
    <NavLink class="nav-link" href="selfservice/korrektur">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
        Korrekturantrag
    </NavLink>
</nav>

<AuthorizeView Roles="Admin">
    <Authorized>
        <nav class="nav-section">
            <span class="nav-label">Administration</span>
            <NavLink class="nav-link" href="admin/aktivitaet">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                </svg>
                Aktivität
            </NavLink>
            <NavLink class="nav-link" href="admin/mitarbeiter">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                Mitarbeiter
            </NavLink>
            <NavLink class="nav-link" href="admin/korrekturen">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Korrekturen
            </NavLink>
            <NavLink class="nav-link" href="admin/exporte">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Exporte
            </NavLink>
            <NavLink class="nav-link" href="admin/sollstunden">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                    <path d="M8 14h.01M12 14h.01M16 14h.01"/>
                </svg>
                Soll-Stunden
            </NavLink>
            <NavLink class="nav-link" href="admin/feiertage">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/>
                    <line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                    <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                </svg>
                Feiertage
            </NavLink>
            <NavLink class="nav-link" href="admin/integritaet">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                Integritätsprüfung
            </NavLink>
            <NavLink class="nav-link" href="admin/einstellungen">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                </svg>
                Einstellungen
            </NavLink>
        </nav>
    </Authorized>
</AuthorizeView>

<div class="nav-spacer"></div>

<AuthorizeView>
    <Authorized>
        <div class="nav-user">
            <div class="nav-user-avatar">@(context.User.Identity?.Name?.Substring(0, Math.Min(2, context.User.Identity?.Name?.Length ?? 0)).ToUpper() ?? "?")</div>
            <div class="nav-user-info">
                <span class="nav-user-name">@context.User.Identity?.Name</span>
                <span class="nav-user-role">Administrator</span>
            </div>
            <a href="/logout" class="nav-logout" title="Abmelden">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 4h4a1 1 0 011 1v14a1 1 0 01-1 1h-4"/><path d="M10 17l5-5-5-5"/><path d="M15 12H3"/>
                </svg>
            </a>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="nav-login-hint">
            <a href="/login" class="nav-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                    <polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/>
                </svg>
                Admin-Login
            </a>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    :host, .nav-brand, .nav-brand-mark, .nav-brand-title, .nav-brand-sub,
    .nav-section, .nav-link, .nav-label,
    .nav-user, .nav-user-avatar, .nav-login-hint, .nav-spacer { all: revert; }

    .nav-brand {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1.25rem 1rem 1.25rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 0.75rem;
    }

    .nav-brand-mark {
        width: 34px; height: 34px;
        border-radius: 8px;
        background: var(--accent);
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .nav-brand-title {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--text);
        letter-spacing: -0.015em;
        line-height: 1.2;
    }

    .nav-brand-sub {
        font-size: 0.6875rem;
        color: var(--text-muted);
        margin-top: 1px;
        line-height: 1;
    }

    .nav-section {
        padding: 0 0.625rem 0.5rem;
    }

    .nav-label {
        display: block;
        font-size: 0.625rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted);
        padding: 0.5rem 0.5rem 0.375rem;
    }

    .nav-link {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.5rem 0.75rem;
        border-radius: 7px;
        color: var(--text-dim);
        text-decoration: none;
        font-size: 0.84375rem;
        font-weight: 450;
        min-height: 38px;
        transition: background 0.1s ease, color 0.1s ease;
        margin-bottom: 1px;
        width: 100%;
        box-sizing: border-box;
        position: relative;
    }

    .nav-link:hover { background: var(--surface-hi); color: var(--text); }
    .nav-link.active {
        background: var(--accent-soft);
        color: var(--accent);
        font-weight: 600;
    }
    .nav-link.active::before {
        content: '';
        position: absolute;
        left: -0.625rem;
        top: 50%; transform: translateY(-50%);
        width: 3px; height: 18px;
        border-radius: 2px;
        background: var(--accent);
    }
    .nav-link svg { flex-shrink: 0; color: var(--text-muted); }
    .nav-link.active svg { color: var(--accent); }
    .nav-link:hover svg { color: var(--text-dim); }

    .nav-spacer { flex: 1; }

    .nav-user {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.875rem 0.75rem;
        border-top: 1px solid var(--border);
        margin-top: auto;
    }

    .nav-user-avatar {
        width: 32px; height: 32px;
        border-radius: 16px;
        background: var(--surface);
        border: 1px solid var(--border-strong);
        color: var(--accent);
        display: flex; align-items: center; justify-content: center;
        font-size: 0.6875rem; font-weight: 600;
        flex-shrink: 0;
        letter-spacing: 0.03em;
    }

    .nav-user-info { flex: 1; overflow: hidden; }
    .nav-user-name { display: block; font-size: 0.78125rem; font-weight: 500; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .nav-user-role { display: block; font-size: 0.6875rem; color: var(--text-muted); margin-top: 1px; }

    .nav-logout {
        display: flex; align-items: center; justify-content: center;
        width: 28px; height: 28px;
        border-radius: 6px;
        border: 1px solid var(--border);
        color: var(--text-dim);
        text-decoration: none;
        flex-shrink: 0;
        transition: background 0.1s, color 0.1s;
    }
    .nav-logout:hover { background: var(--red-bg); color: var(--red-fg); border-color: var(--red-border); }

    .nav-login-hint {
        padding: 0.5rem 0.625rem;
        border-top: 1px solid var(--border);
    }
</style>
